<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="d-flex align-items-baseline flex-wrap" style="gap: 0.3rem 0.5rem;">
        <span class="text-muted small">
          {% if entry.start_date %}
            {{ entry.start_date | date: "%Y-%m" }}
            {% if entry.end_date %} — {{ entry.end_date | date: "%Y-%m" }}{% endif %}
          {% elsif entry.date %}
            {{ entry.date | date: "%Y-%m" }}
          {% endif %}
        </span>
        {% if entry.role and entry.role != '' %}
          <span class="text-muted small">&middot; {{ entry.role }}</span>
        {% endif %}
        {% if entry.name %}
          <strong>&middot; {{ entry.name }}</strong>
        {% endif %}
        {% if entry.institution and entry.institution != '' %}
          <span class="text-muted small">&middot; {{ entry.institution | markdownify | remove: '<p>' | remove: '</p>' }}</span>
        {% endif %}
      </div>
    </li>
  {% endfor %}
</ul>
