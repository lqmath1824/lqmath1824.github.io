<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row align-items-baseline">
        <div class="col-3 ps-4 pe-2">
          <span class="text-muted small">
            {% if entry.start_date %}
              {{ entry.start_date | date: "%Y-%m" }}
              {% if entry.end_date %} — {{ entry.end_date | date: "%Y-%m" }}{% endif %}
            {% elsif entry.date %}
              {{ entry.date | date: "%Y-%m" }}
            {% endif %}
          </span>
        </div>
        <div class="col text-center">
          {% if entry.role and entry.role != '' %}
            <span class="text-muted small">{{ entry.role }}</span>
            {% if entry.name %} &middot; {% endif %}
          {% endif %}
          {% if entry.name %}
            <strong>{{ entry.name }}</strong>
          {% endif %}
        </div>
        <div class="col-3 text-end ps-2 pe-4">
          {% if entry.institution and entry.institution != '' %}
            {% capture inst %}{{ entry.institution | markdownify | remove: '<p>' | remove: '</p>' }}{% endcapture %}
            <span class="text-muted small">{{ inst | replace: '<a ', '<a style="color:inherit;" ' }}</span>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
