<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="interest-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }} interest-icon"></i>
      {% endif %}
      {% if entry.page %}
        <strong><a href="{{ entry.page | relative_url }}">{{ entry.name }}</a></strong>
      {% elsif entry.url %}
        <strong><a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ entry.name }}</a></strong>
      {% else %}
        <strong>{{ entry.name }}</strong>
      {% endif %}
      {% if entry.description %}
        <span class="interest-desc">{{ entry.description }}</span>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .interest-item {
    padding: 0.5rem 0;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .interest-item:not(:last-child) {
    border-bottom: 1px solid var(--global-border-color, #e0e0e0);
  }
  .interest-icon {
    margin-right: 0.4rem;
    color: var(--global-theme-color);
  }
  .interest-desc {
    margin-left: 0.5rem;
    font-size: 0.9rem;
    color: var(--global-text-color-light, #666);
  }
</style>
