<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="interest-item">
      <div class="interest-header">
        {% if entry.icon %}
          <i class="{{ entry.icon }} interest-icon"></i>
        {% endif %}
        {% if entry.page %}
          <strong><a href="{{ entry.page | relative_url }}">{{ entry.name }}</a></strong>
        {% elsif entry.url %}
          <strong><a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ entry.name }}</a></strong>
        {% else %}
          <strong>{{ entry.name }}</strong>
        {% endif %}
        {% if entry.keywords %}
          {% for keyword in entry.keywords %}
            <span class="interest-keyword badge">{{ keyword }}</span>
          {% endfor %}
        {% endif %}
      </div>
      {% if entry.description %}
        <p class="interest-description">{{ entry.description }}</p>
      {% endif %}
      {% if entry.page %}
        <a href="{{ entry.page | relative_url }}" class="interest-more">Read more →</a>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .interest-item {
    padding: 0.5rem 0;
  }
  .interest-item:not(:last-child) {
    border-bottom: 1px solid var(--global-border-color, #e0e0e0);
  }
  .interest-icon {
    margin-right: 0.4rem;
    color: var(--global-theme-color);
  }
  .interest-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .interest-keyword {
    font-size: 0.72rem;
    font-weight: 400;
    background-color: var(--global-theme-color-light, #e8f0fe);
    color: var(--global-theme-color);
    padding: 0.1rem 0.45rem;
    border-radius: 0.25rem;
  }
  .interest-description {
    font-size: 0.9rem;
    color: var(--global-text-color-light, #666);
    margin-top: 0.3rem;
    margin-bottom: 0.2rem;
  }
  .interest-more {
    font-size: 0.85rem;
  }
</style>
